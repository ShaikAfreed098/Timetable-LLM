# LLM API Keys (at least one required for chat functionality)
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LLM Configuration
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# Database — used for local/direct configuration
# When deploying with Docker Compose the individual DB_* vars are used instead.
DB_PASSWORD=changeme
DATABASE_URL=sqlite:///./timetable.db
# Optional: override with individual components (recommended for passwords with special chars)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=timetable_db
# DB_USER=admin
# DB_PASSWORD=changeme

# Redis (optional for local dev, required for production)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRE_MINUTES=1440

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000

# App
DEBUG=false
