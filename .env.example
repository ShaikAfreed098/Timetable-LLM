# ──────────────────────────────────────────────────────────────────────────────
# Timetable-LLM environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# In production (ENVIRONMENT=production) the app refuses to start if critical
# values are missing or still at their placeholder.
# ──────────────────────────────────────────────────────────────────────────────

# --- App ---------------------------------------------------------------------
APP_NAME=Timetable LLM
ENVIRONMENT=development             # development | staging | production
DEBUG=True                          # must be False in production

# --- Security ----------------------------------------------------------------
# Generate with:  openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Database ----------------------------------------------------------------
# Use DATABASE_URL, OR set the individual DB_* vars. Not both.
DATABASE_URL=postgresql+psycopg2://timetable:CHANGE_ME@localhost:5432/timetable_db
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_SSL_MODE=require               # set to "require" in production

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- LLM ---------------------------------------------------------------------
LLM_PROVIDER=openai                 # openai | nvidia | anthropic
LLM_API_KEY=
LLM_BASE_URL=                       # leave blank unless overriding
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# --- Firebase ----------------------------------------------------------------
FIREBASE_PROJECT_ID=

# --- CORS --------------------------------------------------------------------
# Comma-separated list. No wildcards in production.
ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30

# --- SMTP (invite emails) ----------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Postgres container env (docker-compose.prod.yml) ------------------------
POSTGRES_USER=timetable
POSTGRES_PASSWORD=
POSTGRES_DB=timetable_db

# --- Frontend build-time -----------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
